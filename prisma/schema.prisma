// HinSchG — Prisma-Schema
// Phase 1: Datenmodell gemaess ARCHITECTURE.md Abschnitt 4.
//
// Bewusst NICHT vorhanden: IP-Adressen, User-Agent-Logs, Klartext-Token,
// Klartext-Meldungsinhalte, zwingende Hinweisgeber-Identitaet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Meldestelle / Mandant. Multi-Tenant (Phase 9a): mehrere Meldestellen je
// Instanz; Bearbeiter:innen, Faelle und Audit-Eintraege gehoeren je genau einer
// Meldestelle. Die Zugriffstrennung wird serverseitig ueber officeId erzwungen.
model ReportingOffice {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // Deaktivierte Meldestellen nehmen keine neuen Meldungen mehr an und sind
  // oeffentlich nicht erreichbar (Phase 9c, Superadmin-Verwaltung). Bestehende
  // Faelle/Postfaecher bleiben erhalten.
  active    Boolean  @default(true)
  // Managed-Layer (Phase 10a): Tarif + Abo-Status je Meldestelle. Die konkreten
  // Limits stehen in src/lib/plans.ts (Code, nicht DB). Wirksam werden Limits nur,
  // wenn der Managed-Layer aktiviert ist (BILLING_ENABLED=true); Self-Hoster ohne
  // Konfiguration sind unbegrenzt. KEINE Zahlungsdaten in diesem Modell.
  plan       Plan       @default(FREE)
  planStatus PlanStatus @default(ACTIVE)
  createdAt DateTime @default(now())

  // Stufe-2-E2E: Org-Recovery-Keypaar. Der oeffentliche Key ist immer ein
  // Empfaenger (Multi-Recipient), sodass Faelle wiederhergestellt werden koennen,
  // wenn ein Bearbeiter sein Passwort verliert. Der private Key ist mit einer
  // separat verwahrten Org-Recovery-Passphrase verschluesselt.
  recoveryPublicKey          String?
  encryptedRecoveryPrivateKey String?

  handlers Handler[]
  cases    Case[]
}

// Bearbeiter der Meldestelle
model Handler {
  id                  String      @id @default(cuid())
  officeId            String
  office              ReportingOffice @relation(fields: [officeId], references: [id])
  email               String      @unique
  passwordHash        String // Argon2id
  totpSecret          String? // verschluesselt gespeichert
  publicKey           String? // fuer Stufe-2-E2E
  encryptedPrivateKey String? // privater Key, mit passwort-abgeleitetem Key verschluesselt
  role                HandlerRole @default(HANDLER)
  createdAt           DateTime    @default(now())

  @@index([officeId])
}

// Managed-Layer (Phase 10a): Tarife. Konkrete Limits in src/lib/plans.ts.
enum Plan {
  FREE
  PRO
  ENTERPRISE
}

// Abo-Status. SUSPENDED ist fuer den spaeteren Billing-Layer (10b) vorgesehen.
enum PlanStatus {
  ACTIVE
  SUSPENDED
}

enum HandlerRole {
  SUPERADMIN // Plattform-Verwaltung: legt Meldestellen an/deaktiviert sie; KEIN Zugriff auf Fall-Inhalte
  ADMIN // Verwaltung einer Meldestelle, kann Bearbeiter anlegen
  HANDLER // Fallbearbeitung
  AUDITOR // nur Lesezugriff auf Audit-Log
}

// Meldung / Fall
model Case {
  id               String     @id @default(cuid())
  officeId         String
  office           ReportingOffice @relation(fields: [officeId], references: [id])
  tokenHash        String     @unique // Argon2id-Hash des Receipt-Tokens, NIE Klartext
  tokenLookup      String     @unique // deterministischer Blind-Index (HMAC) fuer schnellen Login-Lookup
  category         String?
  severity         Severity   @default(UNSET)
  status           CaseStatus @default(NEW)
  // 1 = Stufe 1 (serverseitig verschluesselt), 2 = Stufe 2 (Ende-zu-Ende).
  encryptionVersion Int       @default(1)
  // Stufe 2: aus dem Receipt-Token abgeleiteter Public Key des Hinweisgebers,
  // an den die Meldestelle Antworten verschluesselt (Server kennt den Token nicht).
  wbPublicKey      String?
  encryptedPayload String // Stufe 1: Ciphertext; Stufe 2: secretbox(content) (Schluessel siehe CaseKey)
  deadlineAck      DateTime // Eingangsbestaetigung: +7 Tage (HinSchG)
  deadlineFeedback DateTime // Rueckmeldung Folgemassnahmen: +3 Monate (HinSchG)
  acknowledgedAt   DateTime?
  feedbackSentAt   DateTime?
  closedAt         DateTime? // gesetzt bei Status CLOSED/REJECTED; Basis fuer Loeschfristen
  createdAt        DateTime   @default(now())

  messages      CaseMessage[]
  attachments   CaseAttachment[]
  statusHistory CaseStatusHistory[]
  keys          CaseKey[]

  @@index([officeId])
  @@index([status])
}

// Stufe-2-E2E: pro Empfaenger verpackter Inhaltsschluessel der Meldung
// (Sealed Box). recipient = handlerId oder "RECOVERY". So koennen mehrere
// Bearbeiter denselben Fall lesen, ohne dass der Server den Schluessel kennt.
model CaseKey {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  recipient  String
  wrappedKey String
  createdAt  DateTime @default(now())

  @@unique([caseId, recipient])
  @@index([caseId])
}

enum Severity {
  UNSET
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CaseStatus {
  NEW
  IN_REVIEW
  INFO_REQUESTED
  ACTION_TAKEN
  CLOSED
  REJECTED
}

// Zwei-Wege-Kommunikation (anonym, ueber Token)
model CaseMessage {
  id            String       @id @default(cuid())
  caseId        String
  case          Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  direction     MsgDirection
  // Stufe 1: Ciphertext. Stufe 2 FROM_OFFICE: Sealed Box an wbPublicKey.
  // Stufe 2 FROM_WHISTLEBLOWER: secretbox(content); Schluessel-Wraps siehe keys.
  encryptedBody String
  createdAt     DateTime     @default(now())

  keys CaseMessageKey[]

  @@index([caseId])
}

// Stufe-2-E2E: Schluessel-Wraps fuer Multi-Recipient-Nachrichten des
// Hinweisgebers an die Meldestelle (analog zu CaseKey, pro Nachricht).
model CaseMessageKey {
  id         String      @id @default(cuid())
  messageId  String
  message    CaseMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient  String
  wrappedKey String
  createdAt  DateTime    @default(now())

  @@unique([messageId, recipient])
  @@index([messageId])
}

enum MsgDirection {
  FROM_WHISTLEBLOWER
  FROM_OFFICE
}

model CaseAttachment {
  id                String   @id @default(cuid())
  caseId            String
  case              Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  encryptedBlobRef  String // Pfad/Ref zum verschluesselten Blob
  encryptedFilename String
  mimeType          String
  sizeBytes         Int
  createdAt         DateTime @default(now())

  @@index([caseId])
}

// Append-only Audit-Trail
model AuditLog {
  id        String   @id @default(cuid())
  actorType String // "HANDLER" | "SYSTEM" | "WHISTLEBLOWER"
  actorId   String?
  action    String // z. B. "CASE_VIEWED", "STATUS_CHANGED", "ACK_SENT"
  caseId    String?
  // Mandantentrennung: jeder Eintrag gehoert zu genau einer Meldestelle, damit
  // der Audit-Trail je Mandant gefiltert werden kann. Nullable fuer alte
  // Eintraege und instanzweite Systemereignisse ohne Office-Bezug.
  officeId  String?
  metadata  Json? // keine PII
  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([officeId])
  @@index([createdAt])
}

model CaseStatusHistory {
  id         String      @id @default(cuid())
  caseId     String
  case       Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fromStatus CaseStatus?
  toStatus   CaseStatus
  changedBy  String // handlerId
  createdAt  DateTime    @default(now())

  @@index([caseId])
}
