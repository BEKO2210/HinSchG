# HinSchG — Beispiel-Umgebungsvariablen
# Kopiere diese Datei nach `.env` und passe die Werte an.
# NIEMALS echte Secrets committen.

# --- Datenbank ---------------------------------------------------------------
# Verbindungsstring zur PostgreSQL-Instanz.
# Bei Nutzung von docker-compose entspricht der Host dem Service-Namen "db".
DATABASE_URL="postgresql://hinschg:hinschg@db:5432/hinschg?schema=public"

# Fuer lokale Entwicklung ohne Docker (Postgres auf localhost):
# DATABASE_URL="postgresql://hinschg:hinschg@localhost:5432/hinschg?schema=public"

# --- Verschluesselung (Stufe 1: at rest) -------------------------------------
# Master-Key fuer die symmetrische Verschluesselung der Meldungsinhalte
# (XChaCha20-Poly1305). 32 Byte, base64-kodiert. Liegt NIE in der Datenbank.
# Generieren z. B. mit:  openssl rand -base64 32
MASTER_ENCRYPTION_KEY="bitte-ersetzen-32-byte-base64-key"

# --- Sessions ----------------------------------------------------------------
# Secret zum Signieren der Bearbeiter-/Postfach-Sessions.
# Generieren z. B. mit:  openssl rand -base64 48
SESSION_SECRET="bitte-ersetzen-langes-zufaelliges-secret"

# --- Postgres-Container (nur fuer docker-compose) ----------------------------
# Werden vom "db"-Service genutzt und muessen zur DATABASE_URL passen.
POSTGRES_USER="hinschg"
POSTGRES_PASSWORD="hinschg"
POSTGRES_DB="hinschg"

# --- Seed (nur fuer `npm run prisma:seed`) -----------------------------------
# Admin-Bearbeiter, der beim Seeding angelegt wird. Das Passwort wird Argon2id-
# gehasht gespeichert und NIE im Klartext persistiert.
SEED_ADMIN_EMAIL="admin@example.org"
SEED_ADMIN_PASSWORD="bitte-starkes-passwort-setzen"
