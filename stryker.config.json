{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation Testing fuer den Sicherheitskern (src/lib). Browser-only- und Singleton-Module sind ausgenommen (wie beim Coverage-Gate). Die App-/Routenschicht deckt Playwright ab.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/lib/**/*.ts",
    "!src/lib/**/*.test.ts",
    "!src/lib/attachments-client.ts",
    "!src/lib/db.ts"
  ],
  "thresholds": {
    "high": 85,
    "low": 70,
    "break": 75
  },
  "timeoutMS": 120000
}
